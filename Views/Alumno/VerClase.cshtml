@model LMS.Models.Entidades.Clase

@{
    Layout = "~/Views/Shared/_LayoutAlumno.cshtml";
    ViewData["Title"] = "Clase";

    var entrega = ViewBag.Entrega as LMS.Models.Entidades.EntregaClase;
}

<div class="container mt-4">

    <!-- ===================== BOTÓN VOLVER ===================== -->
    <a asp-controller="Alumno"
           asp-action="VerCurso"
           asp-route-cursoId="@Model.CursoId"
           class="btn btn-secondary btn-sm mb-3">
        ← Volver al Curso
    </a>

    <!-- ===================== MENSAJES ===================== -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">
            @TempData["Mensaje"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <!-- ===================== CABECERA ===================== -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h2>@Model.Titulo</h2>

            <p class="text-muted mb-2">
                @Model.Descripcion
            </p>

            <hr />

            <h5>Contenido</h5>

            <p style="white-space: pre-line;">
                @Model.ContenidoTexto
            </p>

            @if (!string.IsNullOrEmpty(Model.VideoPath))
            {
                <hr />

                <h5>Imagen de apoyo</h5>

                <img src="@Model.VideoPath"
                     class="img-fluid rounded shadow-sm"
                     style="max-height:500px;" />
            }

        </div>
    </div>

    <!-- ===================== REQUISITOS ===================== -->
    <div class="card mb-4 border-info">
        <div class="card-body">

            <h5 class="text-info">Tipo de entrega requerida</h5>

            <ul class="mb-0">
                @if (Model.RequiereTexto)
                {
                    <li>📝 Respuesta escrita</li>
                }

                @if (Model.RequiereImagen)
                {
                    <li>🖼️ Subir imagen</li>
                }

                @if (!Model.RequiereTexto && !Model.RequiereImagen)
                {
                    <li>Sin entrega requerida</li>
                }
            </ul>

        </div>
    </div>

    <!-- ===================== ENTREGA PREVIA ===================== -->
    @if (entrega != null)
    {
        <div class="card mb-4 border-success">
            <div class="card-body">

                <h5 class="text-success">Tu entrega actual</h5>

                <p>
                    <strong>Fecha:</strong>
                    @entrega.FechaEntrega.ToString("dd/MM/yyyy HH:mm")
                </p>

                @if (!string.IsNullOrWhiteSpace(entrega.Texto))
                {
                    <div class="mb-3">
                        <strong>Texto enviado:</strong>
                        <div class="border rounded p-3 bg-light mt-2"
                             style="white-space: pre-line;">
                            @entrega.Texto
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(entrega.ImagenPath))
                {
                    <div class="mb-3">
                        <strong>Imagen enviada:</strong><br />

                        <img src="@entrega.ImagenPath"
                             class="img-fluid rounded shadow-sm mt-2"
                             style="max-height:400px;" />
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(entrega.ComentarioProfesor))
                {
                    <div class="alert alert-warning mt-3">
                        <strong>Comentario del profesor:</strong><br />
                        @entrega.ComentarioProfesor
                    </div>
                }

            </div>
        </div>
    }

    <!-- ===================== FORMULARIO ===================== -->
    @if (Model.RequiereTexto || Model.RequiereImagen)
    {
        <div class="card shadow-sm">
            <div class="card-body">

                <h4>
                    @(entrega == null ? "Enviar Entrega" : "Actualizar Entrega")
                </h4>

                <form asp-action="EnviarClase"
                      method="post"
                      enctype="multipart/form-data">

                    <input type="hidden"
                           name="claseId"
                           value="@Model.ClaseId" />

                    @if (Model.RequiereTexto)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                Respuesta escrita
                            </label>

                            <textarea name="texto"
                                      class="form-control"
                                      rows="6">@entrega?.Texto</textarea>
                        </div>
                    }

                    @if (Model.RequiereImagen)
                    {
                        <div class="mb-3">
                            <label class="form-label">
                                Subir imagen
                            </label>

                            <input type="file"
                                   name="imagen"
                                   class="form-control" />
                        </div>
                    }

                    <button type="submit"
                            class="btn btn-success w-100">
                        💾 Guardar Entrega
                    </button>

                </form>

            </div>
        </div>
    }

</div>