@model LMS.Models.Entidades.Clase

@{
    ViewData["Title"] = "Vista previa de la clase";
}

<div class="d-flex justify-content-start gap-2 mt-3">
    <!-- Volver al curso -->
    <a asp-controller="Profesor"
           asp-action="Detalle"
           asp-route-id="@Model.CursoId"
           class="btn btn-secondary">
        ← Volver al curso
    </a>

    <!-- Editar Clase -->
    <a asp-controller="Clase"
           asp-action="Editar"
           asp-route-id="@Model.ClaseId"
           class="btn btn-warning btn-sm">
        Editar
    </a>
</div>

<div class="container mt-4">

    <h3>@Model.Titulo</h3>
    <p>@Model.Descripcion</p>

    <hr />

    <h5>Contenido de la clase:</h5>
    <p>@Model.ContenidoTexto</p>

    <!-- Imagen opcional -->
    @if (!string.IsNullOrEmpty(Model.VideoPath))
    {
        <div class="mt-3">
            <h6>Material de apoyo:</h6>
            <img src="@Model.VideoPath" class="img-fluid rounded shadow-sm" />
        </div>
    }

    <hr />

    <!-- 🔥 TIPO DE ENTREGA -->
    <h5>Tipo de entrega requerida:</h5>

    @if (!Model.RequiereTexto && !Model.RequiereImagen)
    {
        <div class="alert alert-warning">
            Esta clase no requiere entrega del estudiante.
        </div>
    }
    else
    {
        <ul class="list-group">

            @if (Model.RequiereTexto)
            {
                <li class="list-group-item">
                    📝 Respuesta escrita requerida
                </li>
            }

            @if (Model.RequiereImagen)
            {
                <li class="list-group-item">
                    🖼️ Subida de imagen requerida
                </li>
            }

        </ul>
    }

</div>