@model LMS.Models.Entidades.Clase

@{
    ViewData["Title"] = "Crear Clase";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0">📘 Nueva Clase</h4>
        </div>

        <div class="card-body">

            <div asp-validation-summary="All" class="text-danger"></div>

            <form method="post" enctype="multipart/form-data">

                <input type="hidden" asp-for="CursoId" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Título</label>
                    <input asp-for="Titulo" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Contenido de la clase</label>
                    <textarea asp-for="ContenidoTexto" class="form-control" rows="5"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Orden</label>
                    <input asp-for="Orden" class="form-control" readonly />
                </div>

                <hr />

                <h5 class="mb-3">📤 Tipo de entrega del estudiante</h5>

                <div class="form-check mb-2">
                    <input asp-for="RequiereTexto" class="form-check-input" />
                    <label class="form-check-label">Respuesta escrita</label>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RequiereImagen" class="form-check-input" />
                    <label class="form-check-label">Subir imagen</label>
                </div>

                <div class="mb-3">
                    <label class="form-label">Imagen opcional de apoyo</label>
                    <input type="file" name="imagen" class="form-control" />
                </div>

                <button class="btn btn-success w-100">
                    💾 Guardar Clase
                </button>

            </form>

        </div>
    </div>
</div>